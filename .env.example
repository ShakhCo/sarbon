# ─────────────────────────────────────────────────────────────
#  Sarbon Dispatcher — environment
#  Copy this file to `.env.local` and fill in the values.
#  These are SERVER-ONLY (no NEXT_PUBLIC_ prefix) so the user
#  JWT never reaches the browser bundle.
# ─────────────────────────────────────────────────────────────

# Upstream API base (no trailing slash)
SARBON_API_BASE_URL=https://api.sarbon.me/v1

# Required upstream auth headers
SARBON_CLIENT_TOKEN=your-x-client-token
SARBON_USER_TOKEN=your-x-user-token
